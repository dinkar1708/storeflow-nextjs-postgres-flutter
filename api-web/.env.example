# Environment Variables Template

# Database - Choose one based on your setup:
# Option 1: Docker PostgreSQL (recommended for local development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/storeflow"
# Option 2: Manual/Local PostgreSQL
# DATABASE_URL="postgresql://YOUR_USERNAME:YOUR_PASSWORD@localhost:5432/storeflow"
# Option 3: Supabase (for production with Vercel)
# DATABASE_URL="postgresql://postgres.PROJECT_ID:YOUR_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="***********************************"
# Generate secret with: openssl rand -base64 32

# App Environment
NODE_ENV="development"
PORT=3001

# Swagger login (HTTP Basic Auth — not NextAuth)
# Protects interactive docs at /api-docs and the OpenAPI JSON at /api/swagger.
# Set BOTH variables to enable; remove or comment out BOTH to leave docs public.
# In the browser: open e.g. http://localhost:3001/api-docs → dialog asks for user + password.
# From CLI: curl -u YOUR_USER:YOUR_PASS http://localhost:3001/api/swagger
SWAGGER_DOCS_USERNAME="***"
SWAGGER_DOCS_PASSWORD="***"

# Optional: Email Configuration
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="***@gmail.com"
EMAIL_SERVER_PASSWORD="***"
EMAIL_FROM="noreply@yourdomain.com"
