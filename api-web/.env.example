# Environment Variables Template

# Database - Choose one based on your setup:
# Option 1: Docker PostgreSQL (recommended)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/storeflow"
# Option 2: Manual/Local PostgreSQL (replace YOUR_USERNAME with your PostgreSQL user)
# DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/storeflow"
# Option 3: Production (set by hosting platform)
# DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Generate secret: openssl rand -base64 32

# App Environment
NODE_ENV="development"
PORT=3001

# Swagger login (HTTP Basic Auth — not NextAuth)
# Protects interactive docs at /api-docs and the OpenAPI JSON at /api/swagger.
# Set BOTH variables to enable; remove or comment out BOTH to leave docs public.
# In the browser: open e.g. http://localhost:3001/api-docs → dialog asks for user + password.
# From CLI: curl -u YOUR_USER:YOUR_PASS http://localhost:3001/api/swagger
SWAGGER_DOCS_USERNAME="docs"
SWAGGER_DOCS_PASSWORD="change-me-in-production"

# Optional: Email Configuration
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="app-password"
EMAIL_FROM="noreply@storeflow.com"
