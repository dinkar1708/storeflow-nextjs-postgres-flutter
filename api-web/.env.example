# Environment Variables Template
# Copy this file to create your environment-specific files:
# - .env.development (for local development with Docker)
# - .env.production (for production deployment)

# Database
# Local (Docker): postgresql://postgres:postgres@localhost:5432/storeflow
# Production: Set by your hosting platform (Vercel, Railway, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/storeflow"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Generate: openssl rand -base64 32

# App Environment
NODE_ENV="development"
PORT=3001

# Optional: Email Configuration
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="app-password"
EMAIL_FROM="noreply@storeflow.com"
