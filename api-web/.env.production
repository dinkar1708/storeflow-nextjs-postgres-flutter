# Production Environment
# NOTE: This file is a template. Actual production values are set in platform environment variables.

# Database - Set by platform (Vercel, Railway, Render)
DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth - Set these in your deployment platform
NEXTAUTH_URL="https://your-app-url.com"
NEXTAUTH_SECRET="generate-secure-secret-with-openssl-rand-base64-32"

# App
NODE_ENV="production"
